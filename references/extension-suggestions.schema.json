{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_type", "status", "notice", "suggestions"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "report_type": {"type": "string", "enum": ["daily", "weekly"]},
    "status": {"type": "string", "enum": ["complete", "partial", "unavailable"]},
    "notice": {"type": "string"},
    "suggestions": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "kind",
          "why_relevant",
          "suggestion",
          "try_next",
          "caveat",
          "based_on_evidence_refs",
          "sources"
        ],
        "properties": {
          "topic": {"type": "string"},
          "kind": {"type": "string", "enum": ["最新进展", "经典参考", "官方文档", "论文", "标准", "工具", "工程实践", "安全"]},
          "why_relevant": {"type": "string"},
          "suggestion": {"type": "string"},
          "try_next": {"type": "string"},
          "caveat": {"type": "string"},
          "based_on_evidence_refs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {"type": "string"}
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "publisher", "url", "published_at", "source_type", "verification"],
              "properties": {
                "title": {"type": "string"},
                "publisher": {"type": "string"},
                "url": {"type": "string"},
                "published_at": {"type": "string"},
                "source_type": {"type": "string", "enum": ["official_docs", "standard", "paper", "original_release", "curated_discovery", "secondary"]},
                "verification": {"type": "string", "enum": ["primary_checked", "corroborated", "discovery_only"]}
              }
            }
          }
        }
      }
    }
  }
}
