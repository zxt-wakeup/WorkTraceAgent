{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_type",
    "period",
    "coverage",
    "work_profile",
    "executive_summary",
    "okr_summary",
    "weekly_highlights",
    "project_progress",
    "decisions_and_learnings",
    "risks_and_actions",
    "next_week_priorities",
    "work_patterns",
    "non_okr_work"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["2.0"]},
    "report_type": {"type": "string", "enum": ["weekly"]},
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "iso_week", "partial_period"],
      "properties": {
        "start": {"type": "string"},
        "end": {"type": "string"},
        "iso_week": {"type": "string"},
        "partial_period": {"type": "boolean"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "caveats"],
      "properties": {
        "status": {"type": "string", "enum": ["complete", "partial", "empty", "error"]},
        "summary": {"type": "string"},
        "caveats": {"type": "array", "maxItems": 20, "items": {"type": "string"}}
      }
    },
    "work_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "updated_at", "source_period", "summary", "facets"],
      "properties": {
        "schema_version": {"type": "string", "enum": ["1.0"]},
        "updated_at": {"type": "string"},
        "source_period": {"type": "string"},
        "summary": {"type": "string"},
        "facets": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["category", "insight", "basis", "confidence", "status", "last_confirmed_for", "evidence_refs"],
            "properties": {
              "category": {
                "type": "string",
                "enum": ["current_focus", "goal_preference", "collaboration_preference", "delivery_preference", "tooling_preference", "recurring_friction", "learning_interest"]
              },
              "insight": {"type": "string"},
              "basis": {"type": "string", "enum": ["explicit_user_statement", "repeated_pattern", "current_period_activity"]},
              "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
              "status": {"type": "string", "enum": ["active", "uncertain"]},
              "last_confirmed_for": {"type": "string"},
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "executive_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "value_delivered", "confidence_note", "evidence"],
      "properties": {
        "headline": {"type": "string"},
        "value_delivered": {"type": "string"},
        "confidence_note": {"type": "string"},
        "evidence": {"type": "string"}
      }
    },
    "okr_summary": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["okr_ref", "trajectory", "summary", "evidence"],
        "properties": {
          "okr_ref": {"type": "string"},
          "trajectory": {"type": "string", "enum": ["推进", "持平", "受阻", "无法判断"]},
          "summary": {"type": "string"},
          "evidence": {"type": "string"}
        }
      }
    },
    "weekly_highlights": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project", "outcome", "value", "status", "evidence", "okr_refs"],
        "properties": {
          "project": {"type": "string"},
          "outcome": {"type": "string"},
          "value": {"type": "string"},
          "status": {"type": "string", "enum": ["已完成", "进行中", "仅提出", "无法确认"]},
          "evidence": {"type": "string"},
          "okr_refs": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}}
        }
      }
    },
    "project_progress": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project", "progress", "final_status", "value", "evidence", "okr_refs"],
        "properties": {
          "project": {"type": "string"},
          "progress": {"type": "string"},
          "final_status": {"type": "string", "enum": ["已完成", "进行中", "仅提出", "无法确认"]},
          "value": {"type": "string"},
          "evidence": {"type": "string"},
          "okr_refs": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}}
        }
      }
    },
    "decisions_and_learnings": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_or_learning", "impact", "evidence", "okr_refs"],
        "properties": {
          "decision_or_learning": {"type": "string"},
          "impact": {"type": "string"},
          "evidence": {"type": "string"},
          "okr_refs": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}}
        }
      }
    },
    "risks_and_actions": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "state", "action", "evidence", "okr_refs"],
        "properties": {
          "risk": {"type": "string"},
          "state": {"type": "string", "enum": ["待处理", "缓解中", "已解决", "无法判断"]},
          "action": {"type": "string"},
          "evidence": {"type": "string"},
          "okr_refs": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}}
        }
      }
    },
    "next_week_priorities": {
      "type": "array",
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task", "reason", "priority", "done_when", "okr_refs"],
        "properties": {
          "task": {"type": "string"},
          "reason": {"type": "string"},
          "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
          "done_when": {"type": "string"},
          "okr_refs": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}}
        }
      }
    },
    "work_patterns": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "impact", "recommendation", "evidence"],
        "properties": {
          "pattern": {"type": "string"},
          "impact": {"type": "string"},
          "recommendation": {"type": "string"},
          "evidence": {"type": "string"}
        }
      }
    },
    "non_okr_work": {
      "type": "array",
      "maxItems": 0,
      "description": "周报不展示未可靠对齐当前 OKR 的内容，必须为空数组。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project", "progress", "final_status", "value", "evidence", "reason_not_aligned"],
        "properties": {
          "project": {"type": "string"},
          "progress": {"type": "string"},
          "final_status": {"type": "string", "enum": ["已完成", "进行中", "仅提出", "无法确认"]},
          "value": {"type": "string"},
          "evidence": {"type": "string"},
          "reason_not_aligned": {"type": "string"}
        }
      }
    }
  }
}
