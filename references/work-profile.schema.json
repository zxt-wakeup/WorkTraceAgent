{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "source_period", "summary", "facets"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "updated_at": {"type": "string"},
    "source_period": {"type": "string"},
    "summary": {"type": "string"},
    "facets": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "insight",
          "basis",
          "confidence",
          "status",
          "last_confirmed_for",
          "evidence_refs"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "current_focus",
              "goal_preference",
              "collaboration_preference",
              "delivery_preference",
              "tooling_preference",
              "recurring_friction",
              "learning_interest"
            ]
          },
          "insight": {"type": "string"},
          "basis": {
            "type": "string",
            "enum": [
              "explicit_user_statement",
              "repeated_pattern",
              "current_period_activity"
            ]
          },
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "status": {"type": "string", "enum": ["active", "uncertain"]},
          "last_confirmed_for": {"type": "string"},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
